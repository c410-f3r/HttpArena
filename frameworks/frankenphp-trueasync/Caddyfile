{
	admin off
	auto_https off
	frankenphp
}

:8080 {
	root * /app
	php_server {
		index off
		file_server off
		worker {
			file /app/worker.php
			num {$WORKERS:0}
			async
			buffer_size 1
			match /*
		}
	}
}

:8443 {
	tls /certs/server.crt /certs/server.key
	root * /app
	php_server {
		index off
		file_server off
		worker {
			file /app/worker.php
			num {$WORKERS:0}
			async
			buffer_size 1
			match /*
		}
	}
}
